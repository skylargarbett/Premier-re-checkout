// ═══════════════════════════════════════
let _agents=[...DA];
let _lockboxes=[...DL];
let _signs=[];
let _history=[];

const ga=()=>_agents;
const gl=()=>_lockboxes;
const gs=()=>_signs;
const gh=()=>_history;
const gu=()=>JSON.parse(localStorage.getItem('prec_user')||'null');
const su=d=>localStorage.setItem('prec_user',JSON.stringify(d));

async function sa(d){_agents=d;await set(ref(db,'agents'),d);}
async function sl(d){_lockboxes=d;await set(ref(db,'lockboxes'),d);}
async function ss(d){_signs=d;await set(ref(db,'signs'),d);}
async function sh2(d){_history=d;await set(ref(db,'history'),d);}

function addHist(type,action,detail,agent){
  const h=gh();
  h.unshift({id:uid(),type,action,detail,agent,timestamp:new Date().toISOString()});
  if(h.length>200)h.splice(200);
  sh2(h);
}

// ═══════════════════════════════════════
// FIREBASE REAL-TIME LISTENERS
// ═══════════════════════════════════════
function initFirebase(){
  // Show loading state
  document.body.insertAdjacentHTML('beforeend','<div id="syncBanner" style="position:fixed;top:0;left:0;right:0;z-index:999;background:var(--bg3);color:var(--silver2);font-size:12px;text-align:center;padding:6px;border-bottom:.5px solid var(--border2)">Connecting...</div>');

  onValue(ref(db,'agents'), snap=>{
    if(snap.exists())_agents=snap.val();
    else set(ref(db,'agents'),DA);
    hideSyncBanner();renderAll();
  });

  onValue(ref(db,'lockboxes'), snap=>{
    if(snap.exists())_lockboxes=snap.val();
    else set(ref(db,'lockboxes'),DL);
    renderAll();
  });

  onValue(ref(db,'signs'), snap=>{
    _signs=snap.exists()?snap.val():[];
    renderAll();
  });

  onValue(ref(db,'history'), snap=>{
    _history=snap.exists()?snap.val():[];
  });

  onValue(ref(db,'oh_total'), snap=>{
    if(snap.exists())localStorage.setItem('prec_oh_total',snap.val());
  });
}

function hideSyncBanner(){
  const b=document.getElementById('syncBanner');
  if(b){b.textContent='Live';b.style.color='var(--green)';setTimeout(()=>b.remove(),1500);}
}

function setOHTotal(){
  const current=localStorage.getItem('prec_oh_total')||'60';
  const val=prompt(`How many open house signs do you have in total?\nCurrent: ${current}`);
  if(val&&!isNaN(val)&&parseInt(val)>0){
    localStorage.setItem('prec_oh_total',parseInt(val));
    set(ref(db,'oh_total'),parseInt(val));
    showToast('Total updated');
    showInventorySheet();
  }
}

// ═══════════════════════════════════════
// UTILS
// ═══════════════════════════════════════
const ini=n=>n.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
const tod=()=>new Date().toISOString().split('T')[0];
const dsi=d=>d?Math.floor((new Date()-new Date(d))/(86400000)):0;
const fmtD=d=>d?new Date(d+'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'—';
const fmtT=ts=>{const d=new Date(ts),n=new Date(),df=Math.floor((n-d)/1000);if(df<60)return'just now';if(df<3600)return Math.floor(df/60)+'m ago';if(df<86400)return Math.floor(df/3600)+'h ago';return d.toLocaleDateString('en-US',{month:'short',day:'numeric'});};
function uid(){return's'+Math.random().toString(36).slice(2,9);}

function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2800);}
function openSheet(id){document.getElementById(id).classList.add('open');}
function closeSheet(id){document.getElementById(id).classList.remove('open');}

// expose closeSheet globally for onclick handlers
window.closeSheet=closeSheet;
window.openSheet=openSheet;

function navTo(pageId,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(pageId).classList.add('active');
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
  if(btn)btn.classList.add('active');
  else{const m={pageHome:0,pageLockboxes:1,pageSigns:2,pageAgents:3,pageSettings:4};const i=m[pageId];if(i!==undefined)document.querySelectorAll('.ni')[i].classList.add('active');}
