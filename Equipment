// INVENTORY
function showInventorySheet(){
  const boxes=gl(),signs=gs();

  // Lockboxes
  const lbTotal=boxes.length;
  const lbOut=boxes.filter(b=>b.status==='checkedout').length;
  const lbAvail=lbTotal-lbOut;

  // For Sale Signs (tracked via lockbox forSaleSign checkbox)
  const fsTotal=boxes.length; // one per lockbox max
  const fsOut=boxes.filter(b=>b.status==='checkedout'&&b.forSaleSign).length;
  const fsAvail=fsTotal-fsOut;

  // Open House Signs — need a total to track against
  const ohTotal=parseInt(localStorage.getItem('prec_oh_total')||'60');
  const ohOut=signs.filter(s=>s.status==='checkedout').reduce((sum,s)=>sum+s.quantity,0);
  const ohAvail=Math.max(0,ohTotal-ohOut);
  const ohOverdue=signs.filter(s=>s.status==='checkedout'&&dsi(s.dateCheckedOut)>=10).length;

  function pct(used,total){return total?Math.round((used/total)*100):0;}
  function bar(used,total){
    const p=pct(used,total);
    const color=p>80?'var(--red)':p>50?'var(--amber)':'var(--green)';
    return`<div style="height:4px;background:var(--bg4);border-radius:2px;margin-top:6px"><div style="height:4px;border-radius:2px;background:${color};width:${p}%"></div></div>`;
  }

  document.getElementById('inventoryDetail').innerHTML=`
    <div style="padding:16px 16px 12px;border-bottom:.5px solid var(--border2)">
      <div style="font-size:11px;font-weight:600;color:var(--silver2);letter-spacing:.06em;text-transform:uppercase;margin-bottom:12px">Lockboxes</div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">Total</span><span style="font-size:14px;font-weight:600">${lbTotal}</span>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">Available</span><span style="font-size:14px;font-weight:600;color:var(--green)">${lbAvail}</span>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">Checked Out</span><span style="font-size:14px;font-weight:600">${lbOut}</span>
      </div>
      ${bar(lbOut,lbTotal)}
    </div>

    <div style="padding:16px 16px 12px;border-bottom:.5px solid var(--border2)">
      <div style="font-size:11px;font-weight:600;color:var(--silver2);letter-spacing:.06em;text-transform:uppercase;margin-bottom:12px">For Sale Signs</div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">Total</span><span style="font-size:14px;font-weight:600">${fsTotal}</span>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">Available</span><span style="font-size:14px;font-weight:600;color:var(--green)">${fsAvail}</span>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">In Use</span><span style="font-size:14px;font-weight:600">${fsOut}</span>
      </div>
      ${bar(fsOut,fsTotal)}
    </div>

    <div style="padding:16px 16px 8px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <div style="font-size:11px;font-weight:600;color:var(--silver2);letter-spacing:.06em;text-transform:uppercase">Open House Signs</div>
        <div style="font-size:12px;color:var(--silver);cursor:pointer" onclick="setOHTotal()">Set total ›</div>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">Total Inventory</span><span style="font-size:14px;font-weight:600">${ohTotal}</span>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">Available</span><span style="font-size:14px;font-weight:600;color:var(--green)">${ohAvail}</span>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:14px;color:var(--text2)">Checked Out</span><span style="font-size:14px;font-weight:600">${ohOut}</span>
      </div>
      ${ohOverdue?`<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-size:14px;color:var(--text2)">Overdue Checkouts</span><span style="font-size:14px;font-weight:600;color:var(--red)">${ohOverdue}</span></div>`:''}
      ${bar(ohOut,ohTotal)}
    </div>
  `;
  openSheet('inventorySheet');
}

function setOHTotal(){
  const current=localStorage.getItem('prec_oh_total')||'60';
  const val=prompt(`How many open house signs do you have in total?\nCurrent: ${current}`);
  if(val&&!isNaN(val)&&parseInt(val)>0){
    localStorage.setItem('prec_oh_total',parseInt(val));
    showToast('Total updated');
    showInventorySheet();
  }
}

