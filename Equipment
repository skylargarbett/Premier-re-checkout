// SIGNS
function renderSigns(){
  const user=gu();
  const signs=gs().filter(s=>s.status==='checkedout');
  signs.sort((a,b)=>new Date(a.dateCheckedOut)-new Date(b.dateCheckedOut));
  const overdue=signs.filter(s=>dsi(s.dateCheckedOut)>=10);
  const active=signs.filter(s=>dsi(s.dateCheckedOut)<10);
  const mine=user?active.filter(s=>s.agent===user.name):[];
  const others=active.filter(s=>!user||s.agent!==user.name);

  const myList=document.getElementById('mySignsList');
  if(!mine.length){myList.innerHTML='<div class="empty" style="padding:20px"><div class="empty-text">You have no active sign checkouts</div></div>';}
  else{const c=document.createElement('div');c.className='card';c.style.margin='0 16px 10px';c.innerHTML=mine.map(s=>signRow(s)).join('');myList.innerHTML='';myList.appendChild(c);}

  const allList=document.getElementById('allSignsList');
  const allActive=[...mine,...others];
  if(!allActive.length){allList.innerHTML='<div class="empty" style="padding:20px"><div class="empty-text">No active sign checkouts</div></div>';}
  else{const c=document.createElement('div');c.className='card';c.style.margin='0 16px 10px';c.innerHTML=allActive.map(s=>signRow(s)).join('');allList.innerHTML='';allList.appendChild(c);}

  const odSec=document.getElementById('overdueSection');
  const odList=document.getElementById('overdueSignsList');
  if(!overdue.length){odSec.style.display='none';}
  else{odSec.style.display='block';const c=document.createElement('div');c.className='card';c.style.margin='0 16px 10px';c.innerHTML=overdue.map(s=>signRow(s,true)).join('');odList.innerHTML='';odList.appendChild(c);}
}

function signRow(s,overdue){
  const days=dsi(s.dateCheckedOut);
  const pill=overdue?'<span class="pill p-over">Overdue</span>':'<span class="pill p-out">Out</span>';
  const badge=`<span class="badge${overdue?' over':days>6?' warn':''}">${days}d</span>`;
  return`<div class="cr" onclick="showSignDetail('${s.id}')">${sgIcon()}<div class="ci"><div class="ct">${s.agent}</div><div class="cs">${s.quantity} sign${s.quantity!==1?'s':''} checked out</div><div class="cm">Since ${fmtD(s.dateCheckedOut)}</div></div><div class="crt">${pill}${badge}</div></div>`;
}

function showSignDetail(id){
