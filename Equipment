// ICONS
function lbIcon(status){
  return`<div class="ii ${status==='available'?'bright':'dim'}"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C10 2 9 3.2 9 4.5C9 5.8 10.3 7 12 7C13.7 7 15 5.8 15 4.5C15 3.2 14 2 12 2Z"/><rect x="6" y="7" width="12" height="15" rx="2.5"/><circle cx="12" cy="13.5" r="1.5"/><path d="M12 15v2.5"/></svg></div>`;
}
function sgIcon(){
  return`<div class="ii bright"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="13" rx="2"/><line x1="6" y1="6.5" x2="18" y2="6.5"/><line x1="6" y1="9.5" x2="15" y2="9.5"/><line x1="6" y1="12" x2="11" y2="12"/><line x1="9" y1="15" x2="9" y2="22"/><line x1="15" y1="15" x2="15" y2="22"/></svg></div>`;
}

// LOCKBOXES
let lbFilter='all';
function filterLB(f,el){lbFilter=f;document.querySelectorAll('.ftb').forEach(t=>t.classList.remove('active'));el.classList.add('active');renderLockboxes();}

function renderLockboxes(){
  const list=document.getElementById('lockboxList');
  let boxes=gl();
  if(lbFilter==='available')boxes=boxes.filter(b=>b.status==='available');
  if(lbFilter==='checkedout')boxes=boxes.filter(b=>b.status==='checkedout');
  boxes.sort((a,b)=>a.status===b.status?a.number.localeCompare(b.number):a.status==='available'?-1:1);
  if(!boxes.length){list.innerHTML='<div class="empty"><div class="empty-icon">🔒</div><div class="empty-text">No lockboxes found</div></div>';return;}
  const card=document.createElement('div');card.className='card';card.style.margin='0 16px 10px';
  card.innerHTML=boxes.map(b=>{
    const pill=b.status==='available'?'<span class="pill p-avail">Available</span>':'<span class="pill p-out">Out</span>';
    const days=b.dateCheckedOut?dsi(b.dateCheckedOut):null;
    const badge=days!==null?`<span class="badge${days>9?' over':days>6?' warn':''}">${days}d</span>`:'';
    return`<div class="cr" onclick="showLockboxDetail('${b.id}')">${lbIcon(b.status)}<div class="ci"><div class="ct">${b.number}</div><div class="cs">${b.agent||'Available'}</div>${b.address?`<div class="cm">${b.address}</div>`:''}</div><div class="crt">${pill}${badge}</div></div>`;
  }).join('');
  list.innerHTML='';list.appendChild(card);
  const ab=document.createElement('div');ab.style.cssText='padding:0 16px 16px';
  ab.innerHTML='<button class="btn btn-o" onclick="showAddLockboxSheet()">+ Add Lockbox</button>';
  list.appendChild(ab);
}

