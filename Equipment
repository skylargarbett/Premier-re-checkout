// SETUP
function showSetup(){
  const sel=document.getElementById('setupAgent');
  sel.innerHTML='<option value="">Select agent...</option>';
  ga().forEach(a=>{const o=document.createElement('option');o.value=a.id;o.textContent=a.name;sel.appendChild(o);});
  document.getElementById('setupScreen').classList.add('open');
}
function completeSetup(){
  const id=document.getElementById('setupAgent').value;
  if(!id){showToast('Please select your name');return;}
  const agents=ga(),agent=agents.find(a=>a.id===id);
  const phone=document.getElementById('setupPhone').value;
  if(phone){agent.phone=phone;sa(agents);}
  su(agent);document.getElementById('setupScreen').classList.remove('open');
