window.showHistorySheet=showHistorySheet;
window.showInventorySheet=showInventorySheet;
window.showAdminPinSheet=showAdminPinSheet;
window.submitAdminPin=submitAdminPin;
window.clearHistory=clearHistory;
window.filterLB=filterLB;
window.setOHTotal=setOHTotal;
window.renderAll=renderAll;

window.addEventListener('load',()=>{
  const user=gu();
  if(!user){
    // Need agents list from Firebase before showing setup
    import('https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js').then(({getDatabase,ref,get,onValue,set})=>{
      initFirebase();
      setTimeout(()=>{
        if(!gu())showSetup();
        else{updateHeader();renderAll();}
      },1200);
    });
  } else {
    initFirebase();
    updateHeader();
    renderAll();
  }
});

document.querySelectorAll('.ov').forEach(ov=>ov.addEventListener('click',e=>{if(e.target===ov)ov.classList.remove('open');}));
</script>
</body>
</html>
